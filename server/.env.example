NODE_ENV=development
PORT=4001
CLIENT_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"
SESSION_COOKIE_NAME="poker_chip_session"
SESSION_TTL_DAYS=30
# Runtime traffic (recommended): Neon pooler URL + bounded connection limit.
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=10"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/poker_chip_tracker?connection_limit=10"

# Migrations / direct connections (usually Neon direct host, not pooler).
# Example:
# DATABASE_URL_DIRECT="postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_DIRECT="postgresql://postgres:postgres@localhost:5432/poker_chip_tracker"
