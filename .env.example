# Frontend (optional; if empty, app uses current host + NEXT_PUBLIC_API_PORT)
NEXT_PUBLIC_API_BASE_URL=""
NEXT_PUBLIC_API_PORT=4001

# Backend (copy into server/.env when running server)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/poker_chip_tracker"
DATABASE_URL_DIRECT="postgresql://postgres:postgres@localhost:5432/poker_chip_tracker"
PORT=4001
NODE_ENV=development
CLIENT_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"
SESSION_COOKIE_NAME="poker_chip_session"
SESSION_TTL_DAYS=30
